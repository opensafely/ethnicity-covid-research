. /* SENSE CHECK OUTCOMES======================================================
> =*/
. foreach i of global outcomes {
  2.                 safetab `i'
  3.                 safetab eth5 `i', row
  4.                 safetab eth16 `i', row
  5.                 
.                 *proportion with diabetes who have the outcome x ethnicity
.                 bysort eth5:safetab  dm_type `i', col
  6.                 bysort eth16: safetab  dm_type `i', col
  7.                 
.                 *proportion of household size who have the outcome x ethnicit
