. 
. foreach i of global outcomes3 {
  2.         forvalues eth=1/5 {
  3.                 
. * Open Stata dataset
. use "$Tempdir/analysis_dataset_STSET_`i'.dta", clear
  4. keep if eth5==`eth'
  5. 
. /* Main hh_model=============================================================
> ====*/
. 
. /* Univariable hh_model */ 
. 
. stcox i.hh_total_cat, strata(stp) nolog
  6. estimates save "$Tempdir/hh_crude_`i'_eth5_`eth'", replace 
  7. parmest, label eform format(estimate p lb ub) saving("$Tempdir/crude_`i'_e
> th5_`eth'", replace) idstr("crude_`i'_eth5_`eth'") 
  8. local hr "`hr' "$Tempdir/crude_`i'_eth5_`eth'" "
  9. 
. 
. /* Multivariable models */ 
. *Age and gender
. stcox i.hh_total_cat i.male age1 age2 age3, strata(stp) nolog
 10. estimates save "$Tempdir/hh_model0_`i'_eth5_`eth'", replace 
 11. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model0_`i'_
> eth5_`eth'", replace) idstr("model0_`i'_eth5_`eth'")
 12. local hr "`hr' "$Tempdir/model0_`i'_eth5_`eth'" "
 13.  
. 
. * Age, Gender, IMD
. 
. stcox i.hh_total_cat i.male age1 age2 age3 i.imd, strata(stp) nolog
 14. if _rc==0{
 15. estimates
 16. estimates save "$Tempdir/hh_model1_`i'_eth5_`eth'", replace 
 17. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model1_`i'_
> eth5_`eth'", replace) idstr("model1_`i'_eth5_`eth'") 
 18. local hr "`hr' "$Tempdir/model1_`i'_eth5_`eth'" "
 19. }
 20. else di "WARNING MODEL1 DID NOT FIT (OUTCOME `i')"
 21. 
. 
. * Age, Gender, IMD and Comorbidities 
. stcox i.hh_total_cat i.male age1 age2 age3      i.imd                        
>                    ///
>                                                                              
>    bmi     hba1c_pct                               ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
>                                                                              
>    i.hypertension bp_map                   ///     
>                                                                              
>    i.asthma                                        ///
>                                                                              
>    i.chronic_respiratory_disease ///
>                                                                              
>    i.chronic_cardiac_disease       ///
>                                                                              
>    i.dm_type                                       ///     
>                                                                              
>    i.cancer                    ///
>                                                                              
>    i.chronic_liver_disease         ///
>                                                                              
>    i.stroke                                        ///
>                                                                              
>    i.dementia                                      ///
>                                                                              
>    i.other_neuro                           ///
>                                                                              
>    i.egfr60                                        ///
>                                                                              
>    i.esrf                                          ///
>                                                                              
>    i.immunosuppressed , strata(stp) nolog          
 22. if _rc==0{
 23. estimates
 24. estimates save "$Tempdir/hh_model2_`i'_eth5_`eth'", replace 
 25. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model2_`i'_
> eth5_`eth'", replace) idstr("model2_`i'_eth5_`eth'") 
 26. local hr "`hr' "$Tempdir/model2_`i'_eth5_`eth'" "
 27. }
 28. else di "WARNING MODEL2 DID NOT FIT (OUTCOME `i')"
 29.                                                                           
>       
.                                                                         
. /* Print table===============================================================
> =*/ 
. *  Print the results for the main hh_model 
. 
. local labeth: label eth5 `eth'
 30. 
. * Column headings 
. file write tablecontent ("`labeth': `i'") _n
 31. 
. * Row headings
. local lab1: label hh_total_cat 1
 32. local lab2: label hh_total_cat 2
 33. local lab3: label hh_total_cat 3
 34. local lab4: label hh_total_cat 4
 35. 
. /* counts */
.  
. * First row, hh_cat =  1 (1-2 ppl) reference cat
.         safecount if hh_total_cat==1
 36.         local denominator = r(N)
 37.         safecount if hh_total_cat ==1 & `i' == 1
 38.         local event = r(N)
 39.     bysort hh_total_cat: egen total_follow_up = total(_t)
 40.         su total_follow_up if hh_total_cat == 1
 41.         local person_week = r(mean)/7
 42.         local rate = 1000*(`event'/`person_week')
 43.         
.         file write tablecontent  ("`lab1'") _tab (`denominator') _tab (`event
> ') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab
 44.         file write tablecontent ("1.00") _tab _tab ("1.00") _tab _tab ("1.
> 00")  _tab _tab ("1.00") _n
 45.         
. * Subsequent household categories
. 
. forvalues hh=2/4 {
 46.         safecount if hh_total_cat==`hh'
 47.         local denominator = r(N)
 48.         safecount if hh_total_cat == `hh' & `i' == 1
 49.         local event = r(N)
 50.         su total_follow_up if hh_total_cat == `hh'
 51.         local person_week = r(mean)/7
 52.         local rate = 1000*(`event'/`person_week')
 53.         file write tablecontent  ("`lab`hh''") _tab (`denominator') _tab  
> (`event') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab  
 54.          estimates use "$Tempdir/hh_crude_`i'_eth5_`eth'" 
 55.          lincom `hh'.hh_total_cat, eform
 56.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 57.          estimates clear
 58.          estimates use "$Tempdir/hh_model0_`i'_eth5_`eth'" 
 59.          lincom `hh'.hh_total_cat, eform
 60.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 61.          estimates clear
 62.          estimates use "$Tempdir/hh_model1_`i'_eth5_`eth'" 
 63.          lincom `hh'.hh_total_cat, eform
 64.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 65.          estimates clear
 66.          estimates use "$Tempdir/hh_model2_`i'_eth5_`eth'" 
 67.          lincom `hh'.hh_total_cat, eform
 68.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _n
 69.          estimates clear
 70. }  //end household categories
 71. 
. }  //end eth5
 72. } //end outcomes
