. 
. foreach i of global outcomes2 {
  2. * Open Stata dataset
. use "$Tempdir/analysis_dataset_STSET_`i'_infected.dta", clear
  3. 
. /* Main inf_model============================================================
> =====*/
. 
. /* Univariable model */ 
. 
. stcox i.eth5, strata(stp) nolog
  4. estimates save "$Tempdir/crude_`i'_eth5", replace 
  5. parmest, label eform format(estimate p lb ub) saving("$Tempdir/crude_`i'_e
> th5", replace) idstr("crude_`i'_eth5") 
  6. local hr "`hr' "$Tempdir/crude_`i'_eth5" "
  7. 
. 
. /* Multivariable models */ 
. *Age and gender
. stcox i.eth5 i.male age1 age2 age3, strata(stp) nolog
  8. estimates save "$Tempdir/model0_`i'_eth5", replace 
  9. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model0_`i'_
> eth5", replace) idstr("model0_`i'_eth5")
 10. local hr "`hr' "$Tempdir/model0_`i'_eth5" "
 11.  
. 
. * Age, Gender, IMD
. 
. stcox i.eth5 i.male age1 age2 age3 i.imd, strata(stp) nolog
 12. if _rc==0{
 13. estimates
 14. estimates save "$Tempdir/model1_`i'_eth5", replace 
 15. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model1_`i'_
> eth5", replace) idstr("model1_`i'_eth5") 
 16. local hr "`hr' "$Tempdir/model1_`i'_eth5" "
 17. }
 18. else di "WARNING MODEL1 DID NOT FIT (OUTCOME `i')"
 19. 
. 
. * Age, Gender, IMD and Comorbidities 
. stcox i.eth5 i.male age1 age2 age3      i.imd                                
>            ///
>                                                                              
>    bmi     hba1c_pct                               ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
>                                                                              
>    i.hypertension bp_map                   ///     
>                                                                              
>    i.asthma                                        ///
>                                                                              
>    i.chronic_respiratory_disease ///
>                                                                              
>    i.chronic_cardiac_disease       ///
>                                                                              
>    i.dm_type                                       ///     
>                                                                              
>    i.cancer                    ///
>                                                                              
>    i.chronic_liver_disease         ///
>                                                                              
>    i.stroke                                        ///
>                                                                              
>    i.dementia                                      ///
>                                                                              
>    i.other_neuro                           ///
>                                                                              
>    i.egfr60                                        ///
>                                                                              
>    i.esrf                                          ///
>                                                                              
>    i.immunosuppressed                      ///
>                                                                              
>    i.ra_sle_psoriasis, strata(stp) nolog           
 20. if _rc==0{
 21. estimates
 22. estimates save "$Tempdir/model2_`i'_eth5", replace 
 23. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model2_`i'_
> eth5", replace) idstr("model2_`i'_eth5") 
 24. local hr "`hr' "$Tempdir/model2_`i'_eth5" "
 25. }
 26. else di "WARNING MODEL2 DID NOT FIT (OUTCOME `i')"
 27. 
.                                                                              
>    
. * Age, Gender, IMD and Comorbidities  and household size and carehome
. stcox i.eth5 i.male age1 age2 age3      i.imd                                
>            ///
>                                                                              
>    bmi     hba1c_pct                               ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
>                                                                              
>    i.hypertension bp_map                   ///     
>                                                                              
>    i.asthma                                        ///
>                                                                              
>    i.chronic_respiratory_disease ///
>                                                                              
>    i.chronic_cardiac_disease       ///
>                                                                              
>    i.dm_type                                       ///     
>                                                                              
>    i.cancer                    ///
>                                                                              
>    i.chronic_liver_disease         ///
>                                                                              
>    i.stroke                                        ///
>                                                                              
>    i.dementia                                      ///
>                                                                              
>    i.other_neuro                           ///
>                                                                              
>    i.egfr60                                        ///
>                                                                              
>    i.esrf                                          ///
>                                                                              
>    i.immunosuppressed                      ///
>                                                                              
>    i.ra_sle_psoriasis                      ///
>                                                                              
>    i.hh_total_cat i.carehome , strata(stp) nolog           
 28. if _rc==0{
 29. estimates
 30. estimates save "$Tempdir/model3_`i'_eth5", replace
 31. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model3_`i'_
> eth5", replace) idstr("model3_`i'_eth5") 
 32. local hr "`hr' "$Tempdir/model3_`i'_eth5" "
 33. }
 34. else di "WARNING MODEL3 DID NOT FIT (OUTCOME `i')"                        
>                               
 35. /* Print table============================================================
> ====*/ 
. *  Print the results for the main inf_model 
. 
. 
. * Column headings 
. file write tablecontent ("`i'") _n
 36. 
. * Row headings 
. local lab1: label eth5 1
 37. local lab2: label eth5 2
 38. local lab3: label eth5 3
 39. local lab4: label eth5 4
 40. local lab5: label eth5 5
 41. 
. /* counts */
.  
. * First row, eth5 = 1 (White) reference cat
.         qui safecount if eth5==1
 42.         local denominator = r(N)
 43.         qui safecount if eth5 == 1 & `i' == 1
 44.         local event = r(N)
 45.     bysort eth5: egen total_follow_up = total(_t)
 46.         qui su total_follow_up if eth5 == 1
 47.         local person_week = r(mean)/7
 48.         local rate = 1000*(`event'/`person_week')
 49.         
.         file write tablecontent  ("`lab1'") _tab (`denominator') _tab (`event
> ') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab
 50.         file write tablecontent ("1.00") _tab _tab ("1.00") _tab _tab ("1.
> 00")  _tab _tab ("1.00") _tab _tab ("1.00") _n
 51.         
. * Subsequent ethnic groups
. forvalues eth=2/5 {
 52.         qui safecount if eth5==`eth'
 53.         local denominator = r(N)
 54.         qui safecount if eth5 == `eth' & `i' == 1
 55.         local event = r(N)
 56.         qui su total_follow_up if eth5 == `eth'
 57.         local person_week = r(mean)/7
 58.         local rate = 1000*(`event'/`person_week')
 59.         file write tablecontent  ("`lab`eth''") _tab (`denominator') _tab 
> (`event') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab  
 60.         cap estimates use "$Tempdir/crude_`i'_eth5" 
 61.         cap cap lincom `eth'.eth5, eform
 62.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 63.         cap estimates clear
 64.         cap estimates use "$Tempdir/model0_`i'_eth5" 
 65.         cap cap lincom `eth'.eth5, eform
 66.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 67.         cap estimates clear
 68.         cap estimates use "$Tempdir/model1_`i'_eth5" 
 69.         cap cap lincom `eth'.eth5, eform
 70.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 71.         cap estimates clear
 72.         cap estimates use "$Tempdir/model2_`i'_eth5" 
 73.         cap cap lincom `eth'.eth5, eform
 74.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 75.         cap estimates clear
 76.         cap estimates use "$Tempdir/model3_`i'_eth5" 
 77.         cap cap lincom `eth'.eth5, eform
 78.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _n
 79. }  //end ethnic group
 80. 
. 
. } //end outcomes

