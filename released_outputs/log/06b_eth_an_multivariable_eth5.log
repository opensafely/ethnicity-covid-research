. 
. cap file close tablecontent

. file open tablecontent using "$Tabfigdir/table2_eth5.txt", write text replace

. file write tablecontent ("Table 2: Association between ethnicity in 16 catego
> ries and COVID-19 outcomes - Complete Case Analysis") _n

. file write tablecontent _tab ("Denominator") _tab ("Event") _tab ("Total pers
> on-weeks") _tab ("Rate per 1,000") _tab ("Crude") _tab _tab ("Age/Sex Adjuste
> d") _tab _tab ("Age/Sex/IMD Adjusted") _tab _tab      ("plus co-morbidities")
>  _tab _tab       ("plus hh size/carehome")  _tab _tab  _n

. file write tablecontent _tab _tab _tab _tab _tab   ("HR") _tab ("95% CI") _ta
> b ("HR") _tab ("95% CI") _tab ("HR") _tab ("95% CI") _tab ("HR") _tab ("95% C
> I") _tab ("HR") _tab ("95% CI") _n

. 
. 
. 
. foreach i of global outcomes {
  2.         di "`i'"
  3. * Open Stata dataset
. use "$Tempdir/analysis_dataset_STSET_`i'.dta", clear
  4. 
. 
. /* Sense check outcomes======================================================
> =*/ 
. 
. safetab eth5 `i', missing row
  5. 
. 
. /* Main Model================================================================
> =*/
. 
. /* Univariable model */ 
. 
. stcox i.eth5, nolog
  6. estimates save "$Tempdir/crude_`i'_eth5", replace 
  7. parmest, label eform format(estimate p lb ub) saving("$Tempdir/crude_`i'_e
> th5", replace) idstr("crude_`i'_eth5") 
  8. local hr "`hr' "$Tempdir/crude_`i'_eth5" "
  9. 
. 
. /* Multivariable models */ 
. *Age and gender
. stcox i.eth5 i.male age1 age2 age3, strata(stp) nolog
 10. estimates save "$Tempdir/model0_`i'_eth5", replace 
 11. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model0_`i'_
> eth5", replace) idstr("model0_`i'_eth5")
 12. local hr "`hr' "$Tempdir/model0_`i'_eth5" "
 13.  
. 
. * Age, Gender, IMD
. 
. stcox i.eth5 i.male age1 age2 age3 i.imd, strata(stp) nolog
 14. if _rc==0{
 15. estimates
 16. estimates save "$Tempdir/model1_`i'_eth5", replace 
 17. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model1_`i'_
> eth5", replace) idstr("model1_`i'_eth5") 
 18. local hr "`hr' "$Tempdir/model1_`i'_eth5" "
 19. }
 20. else di "WARNING MODEL1 DID NOT FIT (OUTCOME `i')"
 21. 
. 
. * Age, Gender, IMD and Comorbidities 
. stcox i.eth5 i.male age1 age2 age3      i.imd                   ///
>                                                                              
>    bmi                                                     ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
>                                                                              
>    i.htdiag_or_highbp                      ///     
>                                                                              
>    i.asthma                                        ///
>                                                                              
>    chronic_respiratory_disease ///
>                                                                              
>    i.chronic_cardiac_disease       ///
>                                                                              
>    i.diabcat                                       ///     
>                                                                              
>    i.cancer                    ///
>                                                                              
>    i.chronic_liver_disease         ///
>                                                                              
>    i.stroke                                        ///
>                                                                              
>    i.dementia                                      ///
>                                                                              
>    i.other_neuro                           ///
>                                                                              
>    i.egfr60                                                ///
>                                                                              
>    i.esrf                                          ///
>                                                                              
>    i.other_immuno                          ///
>                                                                              
>    i.ra_sle_psoriasis, strata(stp) nolog           
 22. if _rc==0{
 23. estimates
 24. estimates save "$Tempdir/model2_`i'_eth5", replace 
 25. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model2_`i'_
> eth5", replace) idstr("model2_`i'_eth5") 
 26. local hr "`hr' "$Tempdir/model2_`i'_eth5" "
 27. }
 28. else di "WARNING MODEL2 DID NOT FIT (OUTCOME `i')"
 29. 
.                                                                              
>    
. * Age, Gender, IMD and Comorbidities  and household size and carehome
. stcox i.eth5 i.male age1 age2 age3 i.imd i.hh_total_cat i.carehome      ///
>                                                                              
>    bmi                                                     ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
