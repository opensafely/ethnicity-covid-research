>    i.ra_sle_psoriasis, strata(stp) nolog                           
 30. if _rc==0{
 31. estimates
 32. estimates save "$Tempdir/model3_`i'_eth5", replace
 33. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model3_`i'_
> eth5", replace) idstr("model3_`i'_eth5") 
 34. local hr "`hr' "$Tempdir/model3_`i'_eth5" "
 35. }
 36. else di "WARNING MODEL3 DID NOT FIT (OUTCOME `i')"
 37. 
.                                                                              
>    
. /* Print table===============================================================
> =*/ 
. *  Print the results for the main model 
. 
. 
. * Column headings 
. file write tablecontent ("`i'") _n
 38. 
. * Row headings 
. local lab1: label eth5 1
 39. local lab2: label eth5 2
 40. local lab3: label eth5 3
 41. local lab4: label eth5 4
 42. local lab5: label eth5 5
 43. 
. /* counts */
.  
. * First row, eth5 = 1 (White British) reference cat
.         qui safecount if eth5==1
 44.         local denominator = r(N)
 45.         qui safecount if eth5 == 1 & `i' == 1
 46.         local event = r(N)
 47.     bysort eth5: egen total_follow_up = total(_t)
 48.         qui su total_follow_up if eth5 == 1
 49.         local person_week = r(mean)/7
 50.         local rate = 1000*(`event'/`person_week')
 51.         
.         file write tablecontent  ("`lab1'") _tab (`denominator') _tab (`event
> ') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab
 52.         file write tablecontent ("1.00") _tab _tab ("1.00") _tab _tab ("1.
> 00")  _tab _tab ("1.00") _tab _tab ("1.00") _n
 53.         
. * Subsequent ethnic groups
. forvalues eth=2/5 {
 54.         qui safecount if eth5==`eth'
 55.         local denominator = r(N)
 56.         qui safecount if eth5 == `eth' & `i' == 1
 57.         local event = r(N)
 58.         qui su total_follow_up if eth5 == `eth'
 59.         local person_week = r(mean)/7
 60.         local rate = 1000*(`event'/`person_week')
 61.         file write tablecontent  ("`lab`eth''") _tab (`denominator') _tab 
> (`event') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab  
 62.         cap estimates use "$Tempdir/crude_`i'_eth5" 
 63.         cap cap lincom `eth'.eth5, eform
 64.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 65.         cap estimates clear
 66.         cap estimates use "$Tempdir/model0_`i'_eth5" 
 67.         cap cap lincom `eth'.eth5, eform
 68.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 69.         cap estimates clear
 70.         cap estimates use "$Tempdir/model1_`i'_eth5" 
 71.         cap cap lincom `eth'.eth5, eform
 72.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 73.         cap estimates clear
 74.         cap estimates use "$Tempdir/model2_`i'_eth5" 
 75.         cap cap lincom `eth'.eth5, eform
 76.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 77.         cap estimates clear
 78.         cap estimates use "$Tempdir/model3_`i'_eth5" 
 79.         cap cap lincom `eth'.eth5, eform
 80.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _n
 81. }  //end ethnic group
 82. 
. 
. } //end outcomes
