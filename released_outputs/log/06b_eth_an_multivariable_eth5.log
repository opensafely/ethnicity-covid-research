. 
. foreach i of global outcomes {
  2.         di "`i'"
  3. 
. * Open Stata dataset
. use "$Tempdir/analysis_dataset_STSET_`i'.dta", clear
  4. 
. /* Main Model================================================================
> =*/
. 
. /* Univariable model */ 
. 
. stcox i.eth5, strata(stp) nolog
  5. estimates save "$Tempdir/crude_`i'_eth5", replace 
  6. parmest, label eform format(estimate p lb ub) saving("$Tempdir/crude_`i'_e
> th5", replace) idstr("crude_`i'_eth5") 
  7. local hr "`hr' "$Tempdir/crude_`i'_eth5" "
  8. 
. 
. /* Multivariable models */ 
. *Age and gender
. stcox i.eth5 i.male age1 age2 age3, strata(stp) nolog
  9. estimates save "$Tempdir/model0_`i'_eth5", replace 
 10. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model0_`i'_
> eth5", replace) idstr("model0_`i'_eth5")
 11. local hr "`hr' "$Tempdir/model0_`i'_eth5" "
 12.  
. 
. * Age, Gender, IMD
. 
. stcox i.eth5 i.male age1 age2 age3 i.imd, strata(stp) nolog
 13. if _rc==0{
 14. estimates
 15. estimates save "$Tempdir/model1_`i'_eth5", replace 
 16. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model1_`i'_
> eth5", replace) idstr("model1_`i'_eth5") 
 17. local hr "`hr' "$Tempdir/model1_`i'_eth5" "
 18. }
 19. else di "WARNING MODEL1 DID NOT FIT (OUTCOME `i')"
 20. 
. 
. * Age, Gender, IMD and Comorbidities 
. stcox i.eth5 i.male age1 age2 age3      i.imd                                
>            ///
>                                                                              
>    bmi     hba1c_pct                               ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
>                                                                              
>    i.hypertension bp_map                   ///     
>                                                                              
>    i.asthma                                        ///
>                                                                              
>    i.chronic_respiratory_disease ///
>                                                                              
>    i.chronic_cardiac_disease       ///
>                                                                              
>    i.dm_type                                       ///     
>                                                                              
>    i.cancer                    ///
>                                                                              
>    i.chronic_liver_disease         ///
>                                                                              
>    i.stroke                                        ///
>                                                                              
>    i.dementia                                      ///
>                                                                              
>    i.other_neuro                           ///
>                                                                              
>    i.egfr60                                        ///
>                                                                              
>    i.esrf                                          ///
>                                                                              
>    i.immunosuppressed                      ///
>                                                                              
>    i.ra_sle_psoriasis, strata(stp) nolog           
 21. if _rc==0{
 22. estimates
 23. estimates save "$Tempdir/model2_`i'_eth5", replace 
 24. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model2_`i'_
> eth5", replace) idstr("model2_`i'_eth5") 
 25. local hr "`hr' "$Tempdir/model2_`i'_eth5" "
 26. }
 27. else di "WARNING MODEL2 DID NOT FIT (OUTCOME `i')"
 28. 
.                                                                              
>    
. * Age, Gender, IMD and Comorbidities  and household size and carehome
. stcox i.eth5 i.male age1 age2 age3      i.imd                                
>            ///
>                                                                              
>    bmi     hba1c_pct                               ///
>                                                                              
>    gp_consult_count                        ///
>                                                                              
>    i.smoke_nomiss                          ///
>                                                                              
>    i.hypertension bp_map                   ///     
>                                                                              
>    i.asthma                                        ///
>                                                                              
>    i.chronic_respiratory_disease ///
>                                                                              
>    i.chronic_cardiac_disease       ///
>                                                                              
>    i.dm_type                                       ///     
>                                                                              
>    i.cancer                    ///
>                                                                              
>    i.chronic_liver_disease         ///
>                                                                              
>    i.stroke                                        ///
>                                                                              
>    i.dementia                                      ///
>                                                                              
>    i.other_neuro                           ///
>                                                                              
>    i.egfr60                                        ///
>                                                                              
>    i.esrf                                          ///
>                                                                              
>    i.immunosuppressed                      ///
>                                                                              
>    i.ra_sle_psoriasis                      ///
>                                                                              
>    i.hh_total_cat i.carehome, strata(stp) nolog            
 29. if _rc==0{
 30. estimates
 31. estimates save "$Tempdir/model3_`i'_eth5", replace
 32. parmest, label eform format(estimate p lb ub) saving("$Tempdir/model3_`i'_
> eth5", replace) idstr("model3_`i'_eth5") 
 33. local hr "`hr' "$Tempdir/model3_`i'_eth5" "
 34. }
 35. else di "WARNING MODEL3 DID NOT FIT (OUTCOME `i')"
 36. 
.                                                                              
>    
. /* Print table===============================================================
> =*/ 
. *  Print the results for the main model 
. 
. 
. * Column headings 
. file write tablecontent ("`i'") _n
 37. 
. * Row headings 
. local lab1: label eth5 1
 38. local lab2: label eth5 2
 39. local lab3: label eth5 3
 40. local lab4: label eth5 4
 41. local lab5: label eth5 5
 42. 
. /* counts */
.  
. * First row, eth5 = 1 (White British) reference cat
.         qui safecount if eth5==1
 43.         local denominator = r(N)
 44.         qui safecount if eth5 == 1 & `i' == 1
 45.         local event = r(N)
 46.     bysort eth5: egen total_follow_up = total(_t)
 47.         qui su total_follow_up if eth5 == 1
 48.         local person_week = r(mean)/7
 49.         local rate = 1000*(`event'/`person_week')
 50.         
.         file write tablecontent  ("`lab1'") _tab (`denominator') _tab (`event
> ') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab
 51.         file write tablecontent ("1.00") _tab _tab ("1.00") _tab _tab ("1.
> 00")  _tab _tab ("1.00") _tab _tab ("1.00") _n
 52.         
. * Subsequent ethnic groups
. forvalues eth=2/5 {
 53.         qui safecount if eth5==`eth'
 54.         local denominator = r(N)
 55.         qui safecount if eth5 == `eth' & `i' == 1
 56.         local event = r(N)
 57.         qui su total_follow_up if eth5 == `eth'
 58.         local person_week = r(mean)/7
 59.         local rate = 1000*(`event'/`person_week')
 60.         file write tablecontent  ("`lab`eth''") _tab (`denominator') _tab 
> (`event') _tab %10.0f (`person_week') _tab %3.2f (`rate') _tab  
 61.         cap estimates use "$Tempdir/crude_`i'_eth5" 
 62.         cap cap lincom `eth'.eth5, eform
 63.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 64.         cap estimates clear
 65.         cap estimates use "$Tempdir/model0_`i'_eth5" 
 66.         cap cap lincom `eth'.eth5, eform
 67.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 68.         cap estimates clear
 69.         cap estimates use "$Tempdir/model1_`i'_eth5" 
 70.         cap cap lincom `eth'.eth5, eform
 71.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 72.         cap estimates clear
 73.         cap estimates use "$Tempdir/model2_`i'_eth5" 
 74.         cap cap lincom `eth'.eth5, eform
 75.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _tab 
 76.         cap estimates clear
 77.         cap estimates use "$Tempdir/model3_`i'_eth5" 
 78.         cap cap lincom `eth'.eth5, eform
 79.         file write tablecontent  %4.2f (r(estimate)) _tab ("(") %4.2f (r(l
> b)) (" - ") %4.2f (r(ub)) (")") _n
 80. }  //end ethnic group
 81. 
. 
. } //end outcomes
