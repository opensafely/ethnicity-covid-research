. 
. foreach i of global outcomes {
  2. * Open Stata dataset
. use "$Tempdir/analysis_dataset_STSET_`i'.dta", clear
  3. 
. * labels 
. local lab1: label eth5 1
  4. local lab2: label eth5 2
  5. local lab3: label eth5 3
  6. local lab4: label eth5 4
  7. local lab5: label eth5 5
  8. 
. *rates by ethnic group and agegroup
. forvalues j=1/7 {
  9.         di "`j'"
 10.         qui strate eth5 if agegroup==`j', per(10000) missing output($Tempd
> ir/strate_`i'_eth5_agegroup`j', replace) ///
>         graph saving("$Tabfigdir/strate_`i'_eth5_agegroup`j'", replace) xlab(
> 1"lab1" 2"lab2" 3"lab3" 4"lab4" 5"lab5") title("`i' agegroup `j'")
 11.         local grapha "`grapha' "$Tabfigdir/strate_`i'_eth5_agegroup`j'" "
 12. } //end agegroup
 13. 
. grc1leg `grapha', altshrink saving("$Tabfigdir/strate_`i'_eth5_age_combined",
>  replace)
 14. graph export "$Tabfigdir/strate_`i'_eth5_age_combined", as(svg) replace
 15. 
. *rates by ethnic group, age, and sex
. forvalues j=1/7 {       
 16.         strate eth5 if agegroup==`j' & male==0, per(10000) missing output(
> $Tempdir/strate_`i'_eth5_agegroup`j'_female, replace) ///
>         graph saving("$Tabfigdir/strate_`i'_eth5_agegroup`j'_female", replace
> ) xlab(1"lab1" 2"lab2" 3"lab3" 4"lab4" 5"lab5") title("`i' agegroup `j' femal
> e")
 17.         local graphf "`graphf' "$Tabfigdir/strate_`i'_eth5_agegroup`j'_fem
> ale" "
 18. } //end agegroup
 19. 
. grc1leg `graphf', altshrink  saving("$Tabfigdir/strate_`i'_eth5_agef_combined
> ", replace)
 20. graph export "$Tabfigdir/strate_`i'_eth5_agef_combined", as(svg) replace
 21. 
. forvalues j=1/7 {       
 22.         strate eth5 if agegroup==`j' & male==1, per(10000) missing output(
> $Tempdir/strate_`i'_eth5_agegroup`j'_male, replace) ///
>         graph saving("$Tabfigdir/strate_`i'_eth5_agegroup`j'_male", replace) 
> xlab(1"lab1" 2"lab2" 3"lab3" 4"lab4" 5"lab5") title("`i' agegroup `j' male")
 23.         local graphm "`graphm' "$Tabfigdir/strate_`i'_eth5_agegroup`j'_mal
> e" "
 24. } //end agegroup
 25. 
. grc1leg `graphm', altshrink  saving("$Tabfigdir/strate_`i'_eth5_agem_combined
> ", replace)
 26. graph export "$Tabfigdir/strate_`i'_eth5_agem_combined", as(svg) replace
 27. 
. 
. 
. 
. } //end outcomes
