. 
. *************************************************CREATE TABLES
. **append datasets
. foreach i of global outcomes {
  2.         use  $Tempdir/strate_`i'_eth5, clear
  3.         gen agegroup=99
  4.         gen male=99
  5.                 forvalues j=1/7 {
  6.                         append using $Tempdir/strate_`i'_eth5_agegroup`j'
  7.                         replace agegroup=`j' if agegroup==.
  8.                         replace male=99 if male==.
  9.                         append using $Tempdir/strate_`i'_eth5_agegroup`j'_
> female
 10.                         replace agegroup=`j' if agegroup==.
 11.                         replace male=0 if male==.
 12.                         append using $Tempdir/strate_`i'_eth5_agegroup`j'_
> male
 13.                         replace agegroup=`j' if agegroup==.
 14.                         replace male=1 if male==.
 15.                 } //end agegroup
 16.         
. gen `i'=1
 17. order `i'
 18. ren _D d_`i'
 19. ren _Y y_`i'
 20. ren _Rate rate_`i'
 21. ren _Lower lb_`i'
 22. ren _Upper ub_`i'
 23. gen unique=_n
 24. save $Tempdir/table7_`i'_eth5.dta, replace
 25. 
. } //end outcomes
