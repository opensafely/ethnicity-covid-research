(5,416,241 real changes made)

. replace smoke = 3  if smoking_status == "S"
(2,779,544 real changes made)

. replace smoke = .u if smoking_status == "M"
(612,669 real changes made, 612,669 to missing)

. replace smoke = .u if smoking_status == "" 
(0 real changes made)

. 
