. /*  Body Mass Index  */
. * NB: watch for missingness
. 
. * Recode strange values 
. replace bmi = . if bmi == 0 
(3,268,130 real changes made, 3,268,130 to missing)

. replace bmi = . if !inrange(bmi, 15, 50)
(117,270 real changes made, 117,270 to missing)

. 
. * Restrict to within 10 years of index and aged > 16 
. gen bmi_time = (indexdate - bmi_measured_date)/365.25
(3,210,743 missing values generated)

. gen bmi_age = age - bmi_time
(3,210,743 missing values generated)

. 
. replace bmi = . if bmi_age < 16 
(45,363 real changes made, 45,363 to missing)

. replace bmi = . if bmi_time > 10 & bmi_time != . 
(0 real changes made)

. 
. * Set to missing if no date, and vice versa 
. replace bmi = . if bmi_measured_date == . 
(0 real changes made)

. replace bmi_measured_date = . if bmi == . 
(220,020 real changes made, 220,020 to missing)

. replace bmi_measured = . if bmi == . 
(3,430,763 real changes made, 3,430,763 to missing)

