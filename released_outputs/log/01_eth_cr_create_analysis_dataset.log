. replace bpcat = .u if bp_sys>=. | bp_dias>=. | bp_sys==0 | bp_dias==0
(5,103,602 real changes made, 5,103,602 to missing)

. 
. label define bpcat 1 "Normal" 2 "Elevated" 3 "High, stage I"    ///
>                                         4 "High, stage II" .u "Unknown"

. label values bpcat bpcat

. 
. recode bpcat .u=1, gen(bpcat_nomiss)
(5103602 differences between bpcat and bpcat_nomiss)

. label values bpcat_nomiss bpcat

. 
. * Create non-missing indicator of known high blood pressure
. gen bphigh = (bpcat==4)

. 
. /*  Hypertension  */
. 
. gen htdiag_or_highbp = bphigh

. recode htdiag_or_highbp 0 = 1 if hypertension==1 
(htdiag_or_highbp: 2154708 changes made)

. 
. *Mean arterial pressure MAP = (SBP+(DBP*2))/3
. gen bp_map=(bp_sys + (bp_dias*2))/3

. ************
. *   eGFR   *
. ************
. 
. * Set implausible creatinine values to missing (Note: zero changed to missing
> )
. replace creatinine = . if !inrange(creatinine, 20, 3000) 
(7,095,763 real changes made, 7,095,763 to missing)

.         
. * Divide by 88.4 (to convert umol/l to mg/dl)
. gen SCr_adj = creatinine/88.4
(7,095,763 missing values generated)

. 
. gen min=.
(16,309,245 missing values generated)

. replace min = SCr_adj/0.7 if male==0
(5,120,751 real changes made)

. replace min = SCr_adj/0.9 if male==1
(4,092,731 real changes made)

. replace min = min^-0.329  if male==0
(5,120,751 real changes made)

. replace min = min^-0.411  if male==1
(4,092,731 real changes made)

. replace min = 1 if min<1
(6,092,308 real changes made)

. 
. gen max=.
(16,309,245 missing values generated)

. replace max=SCr_adj/0.7 if male==0
(5,120,751 real changes made)

. replace max=SCr_adj/0.9 if male==1
(4,092,731 real changes made)

. replace max=max^-1.209
(9,213,482 real changes made)

. replace max=1 if max>1
(10,216,937 real changes made)

. 
. gen egfr=min*max*141
(7,095,763 missing values generated)

. replace egfr=egfr*(0.993^age)
(9,213,482 real changes made)

. replace egfr=egfr*1.018 if male==0
(5,120,751 real changes made)

. label var egfr "egfr calculated using CKD-EPI formula with no eth"

